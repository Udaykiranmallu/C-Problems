#include <stdio.h>

int main() {
    int N;
    scanf("%d", &N);

    int isPrime = 1;

    for(int i = 2; i < N; i++) {
        if(N % i == 0) {
            isPrime = 0;
            break;
        }
    }

    if(isPrime)
        printf("Prime");
    else
        printf("Not Prime");

    return 0;
}
