#include <stdio.h>
int main() {
  int n,digits,reverse=0,original;
  scanf("%d",&n);
  original=n;
  for(;n!=0;n/=10){
    digits=n%10;
    reverse=reverse*10+digits;
  }
  if(original==reverse){
    printf("%d-palindrome",original);
  }
  else{
    printf("%d-is not palindrome",original);
  }
    return 0;
}
