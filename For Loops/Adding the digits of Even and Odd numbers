#include<stdio.h>
int main(){
    int n;
    int sum=0;
    int digit;
    scanf("%d",&n);
    if(n%2==0){
        for(int i=1;i<=n;i++){
            if(i%2==0){
            sum=sum+i;
            }
        }
        printf("%d",sum);

    }
    if(n%2!=0){
        for(int i=1;i<=n;i++){
            if(i%2!=0){
              sum=sum+i;
            }
        }
        printf("%d",sum);
    }
    return 0;
}
