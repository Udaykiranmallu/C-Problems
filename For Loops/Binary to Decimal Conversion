#include <stdio.h>
#include <math.h>

int main() {
    int binary, decimal = 0, remainder, i;
    
    printf("Enter a binary number: ");
    scanf("%d", &binary);

    for(i = 0; binary != 0; i++) {
        remainder = binary % 10;      
        decimal += remainder * pow(2, i); 
        binary = binary / 10;         
    }

    printf("Decimal value = %d", decimal);

    return 0;
}
