#include <stdio.h>

int main() {
    int num1, num2, max, lcm;

    printf("Enter two integers: ");
    scanf("%d %d", &num1, &num2);
    if (num1 > num2)
        max = num1;
    else
        max = num2;
    for (lcm = max; lcm <= num1 * num2; lcm++) {
        if (lcm % num1 == 0 && lcm % num2 == 0) {
            break;
        }
    }

    printf("LCM of %d and %d is %d\n", num1, num2, lcm);

    return 0;
} 
