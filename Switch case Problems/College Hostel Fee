#include <stdio.h>

int main() {
    int roomType;
    int fee;

    scanf("%d", &roomType);

    switch(roomType) {
        case 1:
            fee = 80000;
            break;
        case 2:
            fee = 60000;
            break;
        case 3:
            fee = 45000;
            break;
        default:
            fee = 0;
    }

    if(fee != 0)
        printf("Hostel Fee ₹%d", fee);
    else
        printf("Invalid Room Type");

    return 0;
}
